{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "strict": true,
    "module": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "noImplicitReturns": true,
    "noImplicitAny": true
  },
  "extends": "expo/tsconfig.base",
  "exclude": [
    "node_modules",
    "_bmad-output",
    "**/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
