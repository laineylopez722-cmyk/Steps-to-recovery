# Example environment variables for E2E tests
# Copy to .env and fill in your values

# Test user credentials (for login flow)
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=TestPassword123!

# Optional: Test data customization
TEST_INTENTION=Stay present and focused on recovery
TEST_GRATITUDE=Grateful for another day clean
TEST_REFLECTION=Today was a good day

# Maestro Cloud (optional - for CI)
MAESTRO_CLOUD_API_KEY=your_api_key_here
