# EAS ignore file — keeps archive size small
# Exclude node_modules; EAS will install via eas-build-pre-install hook from monorepo root
# This ensures npm is used (not bun auto-detection), reduces archive size, and keeps builds reproducible

# Dependencies — excluded; installed via eas-build-pre-install
node_modules/
apps/mobile/node_modules/
packages/shared/node_modules/

# Native build artifacts
android/app/build/
android/.gradle/
android/build/
ios/build/
ios/Pods/
ios/DerivedData/

# Test output
coverage/
jest-results/
.maestro/

# Dev tooling (not needed for build)
.vscode/
.turbo/
docs/
docs to reference/

# Large files not needed for bundling
*.log
*.map

# Expo cache
.expo/
