# Steps to Recovery - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Supabase Configuration (REQUIRED)
# =============================================================================
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# Sentry Error Tracking (OPTIONAL - for production monitoring)
# =============================================================================
# Sign up at https://sentry.io and create a React Native project
# Leave blank to disable error tracking

EXPO_PUBLIC_SENTRY_DSN=

# =============================================================================
# Environment Mode (OPTIONAL)
# =============================================================================
# Options: development | staging | production
# Default: development

EXPO_PUBLIC_ENV=development

# =============================================================================
# Setup Instructions
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Create a Supabase project at https://supabase.com
#
# 3. Run the database migrations:
#    - Go to SQL Editor in Supabase dashboard
#    - Run files from supabase/migrations/ in filename order
#
# 4. Copy your Supabase URL and anon key from:
#    Settings > API > Project URL and anon/public key
#
# 5. (Optional) Set up Sentry for error tracking:
#    - Create account at https://sentry.io
#    - Create React Native project
#    - Copy DSN to EXPO_PUBLIC_SENTRY_DSN
#
# 6. Start the app:
#    npm run mobile
#
# =============================================================================
# Security Notes
# =============================================================================
#
# ✅ SAFE TO COMMIT: .env.example (no secrets)
# ❌ NEVER COMMIT: .env (contains real keys)
#
# The Supabase anon key is safe to expose in the client app because:
# - Row-Level Security (RLS) policies protect all data
# - Client-side encryption used for sensitive data
# - Anon key has very limited permissions
#
# The encryption master key is NEVER stored in .env - it's derived from
# the user's session token and stored in device secure storage (Keychain/Keystore)
#
