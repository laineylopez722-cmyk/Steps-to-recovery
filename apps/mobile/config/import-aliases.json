{
  "tsconfigPaths": {
    "@/*": ["./src/*"]
  },
  "babelModuleResolverAlias": {
    "@": "./src"
  },
  "jestModuleNameMapper": {
    "^@/shared$": "<rootDir>/apps/mobile/src/shared/index.ts",
    "^@/(.*)$": "<rootDir>/apps/mobile/src/$1"
  },
  "componentsAliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib"
  }
}
