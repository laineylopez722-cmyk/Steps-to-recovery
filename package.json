{
  "name": "steps-to-recovery-monorepo",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "validate-env": "node scripts/validate-env.js",
    "clean": "turbo run clean",
    "mobile": "npm start -w apps/mobile",
    "web": "npm run web -w apps/mobile",
    "android": "npm run android -w apps/mobile",
    "ios": "npm run ios -w apps/mobile",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
