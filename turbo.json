{
  "$schema": "https://turbo.build/schema.json",

  "globalDependencies": ["**/.env.*local"],

  "tasks": {
    // ── Build ──────────────────────────────────────────────────────────────
    // Compiles all packages.  Output directories are cached so unchanged
    // packages are skipped on subsequent runs.
    "build": {
      "description": "Compile packages with TypeScript / Expo bundler",
      "dependsOn": ["^build"],
      "outputs": [".expo/**", ".next/**", "dist/**"]
    },

    // ── Dev ────────────────────────────────────────────────────────────────
    // Long-running Expo dev server.  Not cached (persistent process).
    "dev": {
      "description": "Start Expo development server (persistent)",
      "cache": false,
      "persistent": true
    },

    // ── Lint ───────────────────────────────────────────────────────────────
    // ESLint across all workspaces.  Not cached because lint results depend
    // on the full working tree (cross-file rules, imports, etc.).
    "lint": {
      "description": "Lint code with ESLint (reports violations, auto-fixes in pre-commit)",
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": false
    },

    // ── Type-check ─────────────────────────────────────────────────────────
    // TypeScript compiler in no-emit mode.  Not cached — tsc must always
    // see the current state of all source files to detect cross-file errors.
    "type-check": {
      "description": "Check types with TypeScript compiler (no emit)",
      "dependsOn": ["^type-check"],
      "outputs": [],
      "cache": false
    },

    // ── Test ───────────────────────────────────────────────────────────────
    // Jest test suite.  Coverage output is cached so unmodified packages
    // don't re-run.  Depends on build so test helpers that import compiled
    // output are resolved correctly.
    "test": {
      "description": "Run tests with Jest and emit coverage reports",
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },

    // ── Clean ──────────────────────────────────────────────────────────────
    // Removes all generated artifacts.  Never cached.
    "clean": {
      "description": "Remove build artifacts, cache directories, and coverage output",
      "cache": false
    }
  }
}
